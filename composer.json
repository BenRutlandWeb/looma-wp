{
    "name": "brw/looma-wp",
    "description": "WordPress installation managed by Composer, improved by Looma",
    "type": "project",
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        },
        {
            "type": "vcs",
            "url": "https://github.com/benrutlandweb/looma"
        },
        {
            "type": "composer",
            "url": "https://connect.advancedcustomfields.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "brw/looma": "dev-main",
        "johnpbloch/wordpress-core-installer": "^2.0",
        "johnpbloch/wordpress-core": "^6.0",
        "symfony/var-dumper": "^7.3",
        "vlucas/phpdotenv": "^5.6",
        "wpengine/advanced-custom-fields-pro": "6.8.0.1"
    },
    "require-dev": {
        "wpackagist-plugin/instant-images": "^7.0",
        "wpackagist-plugin/create-block-theme": "^2.8"
    },
    "extra": {
        "wordpress-install-dir": "public/admin",
        "installer-paths": {
            "public/app/plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "public/app/themes/{$name}/": [
                "type:wordpress-theme"
            ],
            "public/app/mu-plugins/{$name}/": [
                "type:wordpress-muplugin"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "johnpbloch/wordpress-core-installer": true,
            "composer/installers": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "autoload": {
        "psr-4": {
            "App\\": "public/app/themes/looma/app"
        }
    }
}
